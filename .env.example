# Copie para .env e preencha os valores

# Django
SECRET_KEY=sua-chave-secreta-aqui-gere-uma-nova
DEBUG=False
ALLOWED_HOSTS=seu-dominio.railway.app,localhost
CSRF_TRUSTED_ORIGINS=https://seu-dominio.railway.app,https://localhost:8000

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DJANGO_SETTINGS_MODULE=config.settings.production

# Redis/Celery
REDIS_URL=redis://default:password@host:6379
# CELERY_BROKER_URL=redis://default:password@host:6379
# CELERY_RESULT_BACKEND=redis://default:password@host:6379

# IA - análise jurídica
AI_LEGAL_ANALYSIS_PROVIDER=openai
AI_LEGAL_ANALYSIS_MODEL=gpt-5.5
AI_LEGAL_ANALYSIS_API_KEY=
# Alternativas por provedor se AI_LEGAL_ANALYSIS_API_KEY ficar vazia
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Esforço de raciocínio da análise (gpt-5.5): none | low | medium | high | xhigh
# (OpenAI: effort | Gemini: thinkingBudget. Anthropic não aplica em saída estruturada.)
AI_LEGAL_ANALYSIS_REASONING_EFFORT=high
OPENAI_LEGAL_ANALYSIS_TEXT_LIMIT=50000
OPENAI_LEGAL_ANALYSIS_MAX_OUTPUT_TOKENS=4500
OPENAI_LEGAL_ANALYSIS_DOWNLOAD_LIMIT_MB=20
OPENAI_LEGAL_ANALYSIS_OCR_ENABLED=True
OPENAI_LEGAL_ANALYSIS_OCR_LANG=por+eng
OPENAI_LEGAL_ANALYSIS_OCR_DPI=180
OPENAI_LEGAL_ANALYSIS_OCR_MAX_PAGES=25
OPENAI_LEGAL_ANALYSIS_OCR_MIN_PAGE_CHARS=80
OPENAI_LEGAL_ANALYSIS_OCR_TIMEOUT_SECONDS=45

# IA - chat especialista ancorado no imóvel
# Se vazias, herdam o provider/modelo/chave da análise jurídica acima.
AI_CHAT_PROVIDER=
AI_CHAT_MODEL=
AI_CHAT_API_KEY=
AI_CHAT_MAX_OUTPUT_TOKENS=4500
AI_CHAT_CONTEXT_TEXT_LIMIT=40000
AI_CHAT_HISTORY_LIMIT=16
# Chat é interativo: mantenha esforço mínimo para respostas rápidas/baratas.
AI_CHAT_REASONING_EFFORT=none
# Timeout do cliente de IA do chat (deve ser < --timeout do gunicorn).
AI_CHAT_TIMEOUT_SECONDS=100

# (opcional) Email para notificações futuras
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=seu@email.com
# EMAIL_HOST_PASSWORD=sua-senha
